PORT=5000
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=darbak_db
JWT_SECRET=some_secret_key
ENCRYPTION_KEY=your_32_byte_hex_key_here
ENCRYPTION_IV=your_16_byte_hex_iv_here

# --- MinIO / S3 (see docs/MINIO_S3_SETUP.md) ---
# Start: docker compose up -d minio && docker compose run --rm minio_init
#
# MINIO_ENDPOINT = S3 API ONLY (host maps to container 9000). In compose: port 9190.
# NEVER use the console port (9191) — MinIO returns "S3 API Requests must be made to API port".
MINIO_ENDPOINT=127.0.0.1:9190
#
# Credentials = same as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml unless you change them.
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
#
# Bucket must exist (created by minio_init): darbak | darbak-uploads
MINIO_BUCKET=darbak-uploads
#
# Presigned file URLs: host+port the *client device* can reach, SAME API port (9190), not 9191.
# Same machine only: http://127.0.0.1:9190
# Phone / another PC on LAN: http://YOUR_LAN_IP:9190
MINIO_EXTERNAL_URL=http://127.0.0.1:9190
#
# Optional; not read by backend/utils/s3Config.js (SDK uses http when endpoint has no https).
MINIO_USE_SSL=false
